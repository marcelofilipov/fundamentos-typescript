{
    "compilerOptions": {
        "moduleDetection": "force",
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "strictNullChecks": true,
        "target": "ES6",
        "module": "CommonJS",
        "outDir": "out",
        "sourceMap": true,
        "noImplicitOverride": false
    }
}